# VGHTPE credentials
VGH_USERNAME=your_employee_id
VGH_PASSWORD=your_password

# Doctor code for patient list lookup
DOCTOR_CODE=

# OpenRouter API key (for Claude Sonnet 4.6)
OPENROUTER_API_KEY=sk-or-v1-xxxx

# Optional: model override
AI_MODEL=anthropic/claude-sonnet-4-6

# Delays (seconds)
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=3.5
PATIENT_DELAY_MIN=30
PATIENT_DELAY_MAX=60

# Max AI re-crawl rounds (1 = no re-crawl)
MAX_ROUNDS=3
